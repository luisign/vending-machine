$version
	ModelSim Version 10.5b
$end
$timescale
	1ps
$end

$scope module vending_tb $end
$var parameter 3 ! ST_IDLE $end
$var parameter 3 " ST_COLLECT $end
$var parameter 3 # ST_CHECK $end
$var parameter 3 $ ST_DISPENSE $end
$var parameter 3 % ST_CHANGE $end
$var parameter 3 & ST_ERROR $end
$var reg 1 ' clk $end
$var reg 1 ( reset $end
$var reg 2 ) coin_in [1:0] $end
$var reg 2 * sel_item [1:0] $end
$var reg 1 + confirm $end
$var reg 1 , cancel $end
$var reg 1 - dispense $end
$var reg 1 . error_out $end
$var reg 8 / change_out [7:0] $end
$var reg 8 0 display [7:0] $end
$var reg 3 1 state_out [2:0] $end

$scope task apply_coin $end
$var reg 2 2 value [1:0] $end
$upscope $end

$scope task buy_item $end
$var reg 2 3 item [1:0] $end
$upscope $end

$scope task check $end
$var reg 8 4 expected [7:0] $end
$var reg 8 5 actual [7:0] $end
$upscope $end

$scope task wait_until_state $end
$var reg 3 6 target_state [2:0] $end
$upscope $end

$scope task wait_until_idle $end
$upscope $end

$scope task recover_from_error $end
$upscope $end

$scope module dut $end
$var wire 1 7 clk $end
$var wire 1 8 rst $end
$var wire 1 9 coin_in [1] $end
$var wire 1 : coin_in [0] $end
$var wire 1 ; sel_item [1] $end
