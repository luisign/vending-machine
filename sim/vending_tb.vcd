$var reg 3 \ next_state [2:0] $end
$upscope $end

$scope module u_credit_reg $end
$var wire 1 7 clk $end
$var wire 1 8 rst $end
$var wire 1 ] clear $end
$var wire 1 ^ credit_load $end
$var wire 1 _ coin_value [7] $end
